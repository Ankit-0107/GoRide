# Backend Environment Variables
# Copy this file to .env and fill in real values

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/happiness-campaign?retryWrites=true&w=majority

# Mapbox token (server-side only — used for Directions & Geocoding proxy)
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:3000

# Max distance (km) a user can be from a ride to join
MAX_JOIN_DISTANCE_KM=5

# JWT secret for authentication (use a long random string)
JWT_SECRET=replace_with_a_strong_random_secret
